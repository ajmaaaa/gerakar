%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0000000000000000e000000000000000, type: 0}
  m_Name: MovementData_DynamicStretch
  m_EditorClassIdentifier: GerakAR.Content.MovementData
  movementId: dynamic_stretch
  referenceImageName: dynamic_stretch_target
  displayName: Dynamic Stretching
  categoryColor: {r: 0.24705882, g: 0.4862745, b: 0.47058824, a: 1}
  modelPrefab: {fileID: 0}
  animationClip: {fileID: 0}
  keyPoses:
  - normalizedTime: 0
    label: Berdiri tegak
  - normalizedTime: 0.15
    label: Mulai ayunkan kaki
  - normalizedTime: 0.3
    label: Kaki sejajar pinggul
  - normalizedTime: 0.5
    label: Kaki di atas maksimal
  - normalizedTime: 0.7
    label: Turunkan perlahan
  - normalizedTime: 0.85
    label: Ganti sisi
  - normalizedTime: 1
    label: Kembali berdiri
  shortDescription: Gerakan pemanasan untuk melenturkan otot secara aktif dan aman.
  steps:
  - Berdiri tegak dengan tangan di sisi tubuh.
  - Ayunkan satu kaki ke depan setinggi yang nyaman.
  - Ganti kaki dan ulangi dengan ritme yang tenang.
  safetyTips:
  - Jangan memaksa rentang gerak melebihi kemampuan.
  - Lakukan di tempat yang lapang agar tidak tersandung.
  trainedAreas:
  - Paha belakang (Hamstring)
  - Pinggul (Hip Flexors)
  - Punggung bawah
  - Keseimbangan dan koordinasi
  commonMistakes:
  - Gerakan terlalu cepat dan tidak terkontrol.
  - Menahan napas saat melakukan gerakan.
  - Lutut terkunci saat mengayun.
  relatedMovements:
  - title: Standing Toe Touch
    thumbnail: {fileID: 0}
    shortDescription: Ayunkan kaki lurus ke depan dan raih ujung jari kaki.
    steps:
    - Berdiri tegak dan rileks.
    - Ayunkan satu kaki lurus ke depan.
    - Raih ujung kaki dengan tangan yang berlawanan.
    safetyTips:
    - Jangan memaksa jika kaku; gerak perlahan.
  - title: Diagonal Reach
    thumbnail: {fileID: 0}
    shortDescription: Raih diagonal silang untuk melatih koordinasi dan fleksibilitas.
    steps:
    - Berdiri kaki selebar bahu.
    - Raih tangan kanan ke arah kaki kiri bawah.
    - Ganti sisi secara bergantian.
    safetyTips:
    - Jaga punggung tetap lurus saat membungkuk.
  - title: Trunk Rotation
    thumbnail: {fileID: 0}
    shortDescription: Rotasi batang tubuh untuk melenturkan pinggang dan punggung.
    steps:
    - Berdiri kaki selebar bahu, tangan di pinggang.
    - Putar tubuh ke kanan sejauh nyaman.
    - Kembali tengah lalu putar ke kiri.
    safetyTips:
    - Rotasi dari pinggang, bukan hanya bahu.
  - title: High Knee March
    thumbnail: {fileID: 0}
    shortDescription: Marching dengan lutut tinggi untuk memanaskan seluruh kaki.
    steps:
    - Berdiri tegak dengan tangan di sisi tubuh.
    - Angkat lutut kanan setinggi pinggul.
    - Ganti kaki bergantian seperti berjalan di tempat.
    safetyTips:
    - Tetap tegak dan jangan condong ke belakang.
  audioGuide: {fileID: 0}
